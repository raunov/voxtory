# Gemini API Configuration
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# API Authentication Tokens
# Multiple tokens can be specified as comma-separated values
# If not set, a random token will be generated on startup
API_TOKEN=your_api_token_here

# API Rate Limiting
# Number of requests allowed per minute per API token
RATE_LIMIT=10

# Environment Type (development or production)
ENVIRONMENT=development

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
